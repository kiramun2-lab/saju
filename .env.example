# ——— 토스페이먼츠 (Toss Payments) ———
# 개발자센터 https://developers.tosspayments.com/my/api-keys
# 결제위젯 연동 키 (클라이언트) — 브라우저에 노출돼도 됨
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxx
# 시크릿 키 — 서버(API 라우트)에서만 사용, 절대 클라이언트에 노출 금지
TOSS_SECRET_KEY=test_sk_xxxx

# ——— 카카오 로그인 ———
# https://developers.kakao.com 콘솔 > 앱 > 앱 키 > JavaScript 키
NEXT_PUBLIC_KAKAO_JS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REST API 키 (서버에서 토큰 교환 시 사용)
KAKAO_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 카카오 로그인 후 돌아올 URL (콘솔에 등록한 Redirect URI와 정확히 일치)
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/oauth/callback/kakao
